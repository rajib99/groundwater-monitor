# ─────────────────────────────────────────────────────────────────────────────
# Groundwater Monitor — environment configuration
# Copy to .env and fill in every value before deploying.
# Never commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployment target ─────────────────────────────────────────────────────────
# Fully-qualified domain name served by Nginx.
DOMAIN=monitor.example.com

# Docker image registry and tag (CI sets IMAGE_TAG to the git SHA automatically)
REGISTRY=ghcr.io/your-github-username
IMAGE_TAG=latest

# ── PostgreSQL / TimescaleDB ──────────────────────────────────────────────────
POSTGRES_DB=groundwater
POSTGRES_USER=gwm_user
POSTGRES_PASSWORD=changeme_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── FastAPI backend ───────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32

ENVIRONMENT=production
LOG_LEVEL=INFO

# Comma-separated CORS origins — use your public HTTPS domain in production
BACKEND_CORS_ORIGINS=https://monitor.example.com

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Internal URL used by Next.js server-side rewrites; never exposed to browser
NEXT_PUBLIC_API_URL=http://backend:8000

# ── Anthropic AI ─────────────────────────────────────────────────────────────
# Leave empty to disable AI summaries and report executive summaries
ANTHROPIC_API_KEY=

# ── Live feed simulator ───────────────────────────────────────────────────────
SIMULATOR_INTERVAL_S=30
ANOMALY_PROB=0.05

# ── SSL / Certbot ─────────────────────────────────────────────────────────────
CERTBOT_EMAIL=ops@example.com
