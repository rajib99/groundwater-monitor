# ── PostgreSQL / TimescaleDB ─────────────────────────────────────────────────
POSTGRES_DB=groundwater
POSTGRES_USER=gwm_user
POSTGRES_PASSWORD=changeme_strong_password

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Backend (FastAPI) ────────────────────────────────────────────────────────
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated allowed origins for CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Exposed to the browser — never put secrets here
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── ML ───────────────────────────────────────────────────────────────────────
ML_MODEL_PATH=/app/models
# How many days of historical data to use for forecasting
ML_FORECAST_HORIZON_DAYS=30
